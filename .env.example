# Google Gemini AI API Configuration
# Add this as a server-side environment variable in Vercel (or your .env.local for local dev).
# This key is NEVER exposed to the client — all AI requests are securely proxied through /api/ai.
# If left empty, the application automatically falls back to its built-in local AI rule engine.
GEMINI_API_KEY=your_gemini_api_key_here
